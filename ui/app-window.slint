
import { ScrollView, LineEdit, StandardButton } from "std-widgets.slint";

struct ChannelData {
    channel_title: string,
    channel_url: string,
}
//TODO: add the thing to show all the episodes
struct EpisodeData {
    episode_title: string,
    audio_url: string,
}

component ChannelBox inherits Rectangle {
    height: 30px;
    background: purple;
    in property <ChannelData> channelInfo;
    callback clicked(ChannelData);

    TouchArea {
        clicked => {clicked(root.channelInfo);}

        Text {
            color: white;
            horizontal-alignment: left;
            text: channelInfo.channel_title;   
        }
    }
}

component EpisodeBox inherits Rectangle {
    height: 30px;
    width:  (640px / 2) - 10px;
    background: green;
    in property <EpisodeData> episodeInfo;
    callback clicked (EpisodeData);
    
    TouchArea {
        clicked => {clicked(root.episodeInfo);}
        Text {
            color: white;
            horizontal-alignment: left;
            wrap: word-wrap;
            text: episodeInfo.episode_title;   
        }
    }
}

export component MainWindow inherits Window {
    title: @tr("rss-frida");
    
    property <bool> show-new-feed-dialog: false;
    in property <[ChannelData]> channels;
    in property <[EpisodeData]> episodes;

    callback submit-feed(string);
    callback select-channel(ChannelData);
    callback select-episode(EpisodeData);
    
    min-height: 480px;
    min-width: 640px;
    
    MenuBar {
        Menu {
            title: @tr("File");
            MenuItem {
                title: @tr("New Feed...");
                activated => {show-new-feed-dialog = true;}
            }
        }
    }

    HorizontalLayout {
        alignment: center;
        spacing: 10px;

        ChannelBoxBox := Rectangle {
            width:  (640px / 2) - 10px;
            background: root.background.darker(0.05);
            
            ScrollView {
                VerticalLayout {
                    for channel in root.channels:
                        ChannelBox {
                            channelInfo: channel;
                            clicked(info) => {root.select-channel(info);}
                        }
                }
            }
        }
//this is where the episodes will go
        EpisodeBoxBox := Rectangle {
            width: (640px / 2) - 10px;
            background: root.background.darker(0.05);

            ScrollView {
                width: parent.width;
                VerticalLayout {
                    for episode in root.episodes:
                    EpisodeBox{
                        episodeInfo: episode;
                        clicked(info) => {root.select-episode(episode)}
                    }
                }
            }
        }
    
    }

    if show-new-feed-dialog: 
        
    new-feed-dialog := Rectangle{
            height: 100px;
            width: 300px;
            background: parent.background.darker(0.2);
            
            feed_url := LineEdit {
            width: 200px;
            y: 15px;
            placeholder-text: @tr("Feed URL");
        }
            HorizontalLayout {
                height: 30px;
                alignment: center;
                y: parent.height - self.height - 10px;
                x: (parent.width - self.width) / 2;
                spacing: 5px;
                StandardButton {
                    kind: ok;
                    width: 80px;
                    clicked => {submit-feed(feed_url.text); show-new-feed-dialog = false;}
                }
                StandardButton {
                    kind: cancel;
                    width: 80px;
                    clicked => {show-new-feed-dialog = false;}
                }
            }       
    }
}